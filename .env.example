# Copy to .env and fill in. The ui_server reads these via the environment.
# (uvicorn does not auto-load .env; export them or `set -a; source .env; set +a`.)

# Base URL of your locally-running freellmapi proxy (default shown).
FREELLMAPI_BASE_URL=http://localhost:3001

# The unified key from the proxy's Keys page. REQUIRED for LLM calls.
FREELLMAPI_KEY=freellmapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model id ("auto" lets the proxy router choose).
FREELLMAPI_MODEL=auto

# Optional: per-request timeout in seconds.
FREELLMAPI_TIMEOUT=120
